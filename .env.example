SUPABASE_DB_URL=jdbc:postgresql://db.your-project.supabase.co:5432/postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=replace-me
# Spring Boot also accepts these names directly:
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require&currentSchema=public
# SPRING_DATASOURCE_USERNAME=postgres.your-project-ref
# SPRING_DATASOURCE_PASSWORD=replace-me
JWT_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:3000,https://ironman-frontend.vercel.app
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=None
PORT=8080
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace-me
MAIL_PASSWORD=replace-me
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_FROM=noreply@ironman-laundry.com
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_FROM=replace-me
FCM_ENABLED=false
FCM_SERVER_KEY=replace-me
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.10
PAYMENT_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_BKASH_SECRET=
PAYMENT_WEBHOOK_NAGAD_SECRET=
PAYMENT_WEBHOOK_ROCKET_SECRET=
PAYMENT_WEBHOOK_CARD_SECRET=
PAYMENT_WEBHOOK_SIGNATURE_TOLERANCE=PT5M
PAYMENT_WEBHOOK_MAX_ATTEMPTS=6
PAYMENT_WEBHOOK_RETRY_BASE_DELAY=PT5M
PAYMENT_WEBHOOK_RETRY_FIXED_DELAY_MS=60000
STRICT_ENV_VALIDATION=false
